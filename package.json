{
  "name": "traicebox",
  "version": "0.1.0",
  "description": "A zero-config local developer stack for tracing and session tracking around LLM and AI model workflows.",
  "keywords": [
    "ai",
    "llm",
    "tracing",
    "observability",
    "debugging",
    "developer-tools",
    "cli",
    "zero-config",
    "session-tracking"
  ],
  "type": "module",
  "bin": {
    "traicebox": "./dist/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "traicebox": "TRAICEBOX_DEV=1 bun ./cli/index.ts",
    "build": "bun build ./cli/index.ts --outdir ./dist --target node",
    "prepublishOnly": "bun run build",
    "test": "bun test",
    "typecheck": "tsc",
    "check": "biome check .",
    "fix": "biome check --write ."
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.12",
    "@types/bun": "^1.3.12",
    "@types/yargs": "^17.0.35",
    "typescript": "^6.0.2"
  },
  "dependencies": {
    "ora": "^9.3.0",
    "yaml": "^2.8.3",
    "yargs": "^18.0.0"
  }
}
